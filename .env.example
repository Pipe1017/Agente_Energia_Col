# ============================================================
# Agente Energia Col — Variables de Entorno
# cp .env.example .env  →  ajustar valores antes de levantar
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=energia_user
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=energia_col
POSTGRES_PORT=5432

# Base de datos de Airflow (dentro del mismo postgres)
AIRFLOW_DB=airflow

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_PORT=6379

# ------------------------------------------------------------
# MinIO  (almacenamiento de artefactos S3-compatible)
# ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_secure_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------
# Airflow
# Generar Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generar Secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here
AIRFLOW_SECRET_KEY=your_generated_secret_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_UID=1000

# ------------------------------------------------------------
# LLM Provider — deepseek (prod) | ollama (dev local) | openai
# ------------------------------------------------------------
LLM_PROVIDER=deepseek

# Deepseek (producción)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama (desarrollo local — sin costo)
# Instalar: https://ollama.com  →  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------
# MLflow — tracking server
# ------------------------------------------------------------
MLFLOW_PORT=5000
# MLFLOW_TRACKING_URI se configura automáticamente en docker-compose
# Artefactos: MLflow usa MinIO (bucket 'mlflow') como S3-compatible store

# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
API_PORT=8000
LOG_LEVEL=info

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
VITE_API_URL=http://localhost:8000
